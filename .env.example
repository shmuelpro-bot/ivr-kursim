# ═══════════════════════════════════════════════════════════════
#  IVR דירות לשבת – משתני סביבה נדרשים
#  העתק קובץ זה ל-.env והזן את הערכים האמיתיים
#  לעולם אל תעלה .env ל-GitHub!
# ═══════════════════════════════════════════════════════════════

# ── Twilio (IVR + SMS OTP) ──────────────────────────────────────
# הרשם ב: https://console.twilio.com
# ללא משתנים אלו: SMS לא נשלח, OTP מוצג על המסך (מצב בדיקה)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+972XXXXXXXXX

# ── Upstash Redis (אחסון נתונים) ────────────────────────────────
# הרשם ב: https://console.upstash.com → צור Database → REST API
# ללא משתנים אלו: נתונים נשמרים בקבצים ב-/data/ (ephemeral)
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── System ──────────────────────────────────────────────────────
# כתובת ה-URL הציבורית של ivr_main.php
IVR_SELF_URL=https://ivr-kursim.onrender.com/ivr_main.php

# סיסמת כניסה ללוח הניהול (admin.php)
ADMIN_PASSWORD=Shabbat@2024!

# מפתח סודי לקריאת ה-cron endpoint (Render יוצר אוטומטית)
CRON_SECRET=shabbat_cleanup_2024
