# ─────────────────────────────────────────────
#  IVR דירות לשבת – משתני סביבה
#  העתק קובץ זה ל-.env ומלא את הערכים האמיתיים
# ─────────────────────────────────────────────

# טוקן ה-API של call2all / ימות המשיח
# ניתן למצוא בממשק הניהול תחת "API"
CALL2ALL_TOKEN=0772519703_XXXXXXXXXX

# כתובת ה-URL הציבורית של ivr_main.php (ללא סלאש בסוף)
# לדוגמה ב-render.com:
IVR_SELF_URL=https://ivr-kursim.onrender.com/ivr_main.php

# סיסמת כניסה ללוח הניהול (admin.php)
ADMIN_PASSWORD=Shabbat@2024!

# מפתח סודי לקריאת ה-cron endpoint
# לדוגמה: curl "https://.../cron.php?secret=MY_SECRET"
CRON_SECRET=cron_change_me
